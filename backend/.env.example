# Example .env for backend
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
PORT=5000
# Set to 'true' during development to always return mock coupons
FORCE_MOCK_COUPONS=true
# Set to 'true' to make the /api/create-coupon endpoint return 500 on Stripe errors
STRICT_STRIPE_ERRORS=false
